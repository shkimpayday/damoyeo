# ============================================================
# 다모여 환경변수 예시 파일
# EC2 서버의 ~/damoyeo/.env 파일로 사용
# (이 파일은 GitHub에 커밋해도 됩니다 - 실제 값이 없음)
# ============================================================

# Docker Hub 계정
DOCKER_USERNAME=your-dockerhub-username

# MariaDB 설정
DB_USERNAME=damoyeo
DB_PASSWORD=your-strong-password-here
DB_ROOT_PASSWORD=your-root-password-here

# JWT 시크릿 (최소 256비트, 무작위 문자열 권장)
# 생성 방법: openssl rand -base64 64
JWT_SECRET=your-jwt-secret-key-must-be-at-least-256-bits-long-change-this

# Gmail SMTP (앱 비밀번호 사용)
# Gmail → 2단계 인증 → 앱 비밀번호에서 생성
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# CORS 허용 출처 (EC2 퍼블릭 IP 또는 도메인)
# 예: http://13.125.123.456  또는  https://damoyeo.com
CORS_ALLOWED_ORIGINS=http://your-ec2-public-ip

# 프론트엔드 URL (카카오페이 콜백 등)
FRONTEND_URL=http://your-ec2-public-ip
